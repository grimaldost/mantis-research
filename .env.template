# Copy to .env (which is gitignored). Required for the OpenRouter stage.

# OpenRouter API key (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=

# Optional attribution headers (used by OpenRouter for usage leaderboards)
MANTIS_HTTP_REFERER=https://github.com/grimaldost/mantis-research
MANTIS_APP_TITLE=mantis-research

# Interface gating — comma-separated stage names refused at CLI dispatch.
# Useful for declaring which provider CLIs / subscriptions are unavailable
# on this machine so attempts to invoke them fail fast with a helpful error.
#
# Valid names: claude, gemini, openrouter, synthesis, journal-passes,
# falsification. Common usage: set this to `gemini` when adopting Path B
# from prompts/playbooks/research-path-recommendation.md (Gemini Advanced
# subscription dropped, use Gemini-via-OR instead).
#
# Example: DISABLED_STAGES=gemini
DISABLED_STAGES=
